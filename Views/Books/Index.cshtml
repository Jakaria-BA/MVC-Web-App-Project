@model IEnumerable<LibraryManagementSystem.Models.Book>

@{
    ViewData["Title"] = "Browse Books";
}

<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
    <h2>Browse Books</h2>
    @if (User.IsInRole("Librarian"))
    {
        <a asp-action="Create" class="btn btn-primary">+ Add New Book</a>
    }
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div style="background-color: rgba(34, 197, 94, 0.2); color: #86efac; padding: 1rem; border-radius: 8px; margin-bottom: 1.5rem; border: 1px solid rgba(34, 197, 94, 0.3);">
        @TempData["SuccessMessage"]
    </div>
}

<form asp-action="Index" method="get" style="margin-bottom: 2rem;">
    <div style="display: flex; gap: 1rem; max-width: 500px;">
        <input type="text" name="searchString" class="form-control" placeholder="Search by title or author..." />
        <button type="submit" class="btn btn-primary">Search</button>
    </div>
</form>

<div class="book-grid">
    @foreach (var item in Model) {
        <div class="book-card glass-panel" style="padding: 0; overflow: hidden;">
            @if (!string.IsNullOrEmpty(item.CoverImageURL))
            {
                <img src="@item.CoverImageURL" alt="Cover of @item.Title" class="book-cover" style="width:100%; height:250px; object-fit:cover;" />
            }
            <div class="book-info" style="padding: 1.5rem;">
                <h3 class="book-title">@item.Title</h3>
                <p class="book-author">By @item.Author</p>

                <div style="margin-bottom: 1rem;">
                    @if (item.AvailableCopies > 0)
                    {
                        <span class="badge badge-success">Available (@item.AvailableCopies / @item.TotalCopies)</span>
                    }
                    else
                    {
                        <span class="badge badge-danger">Out of Stock</span>
                    }
                </div>

                <div style="margin-top: auto; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                    @* Borrow button: visible to authenticated non-Librarian members only *@
                    @if (User.Identity != null && User.Identity.IsAuthenticated && !User.IsInRole("Librarian"))
                    {
                        @if (item.AvailableCopies > 0)
                        {
                            <a asp-controller="Loans" asp-action="Create" asp-route-bookISBN="@item.ISBN"
                               class="btn btn-primary btn-sm" style="flex: 1; text-align: center;">
                                📚 Borrow Book
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary btn-sm" style="flex: 1;" disabled>Unavailable</button>
                        }
                    }

                    @if (User.IsInRole("Librarian"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.ISBN" class="btn btn-secondary btn-sm">Edit</a>
                        <a asp-action="Delete" asp-route-id="@item.ISBN" class="btn btn-danger btn-sm">Delete</a>
                    }
                </div>
            </div>
        </div>
    }
</div>
