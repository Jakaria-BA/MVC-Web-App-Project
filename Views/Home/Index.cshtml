@{
    ViewData["Title"] = "Home Page";
}

<div class="hero">
    <h1>Welcome to Nexus Library</h1>
    <p>Discover thousands of books, manage your loans, and explore a world of knowledge.</p>
    
    @if (!User.Identity?.IsAuthenticated == true)
    {
        <div style="margin-top: 2rem; display: flex; gap: 1rem; justify-content: center;">
            <a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary" style="font-size: 1.1rem; padding: 0.75rem 2rem;">Join Now</a>
            <a asp-area="Identity" asp-page="/Account/Login" class="btn btn-secondary" style="font-size: 1.1rem; padding: 0.75rem 2rem;">Sign In</a>
        </div>
    }
</div>

