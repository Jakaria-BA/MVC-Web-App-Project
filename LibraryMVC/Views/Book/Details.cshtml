@model LibraryMVC.Models.Book

@{
    ViewData["Title"] = "Book Details";
}

<div class="container mt-4">
    <h1>Book Details</h1>

    <div class="card">
        <div class="card-body">
            <h4 class="card-title">@Model.Title</h4>
            <hr />
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Author)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Author)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Genre)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Genre)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.IsAvailable)</dt>
                <dd class="col-sm-9">
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Borrowed</span>
                    }
                </dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Library)</dt>
                <dd class="col-sm-9">@(Model.Library?.Name ?? "Not assigned")</dd>
            </dl>
            <div class="mt-3">
                <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit</a>
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
                @if (Model.IsAvailable)
                {
                    <a asp-controller="Transaction" asp-action="Create" asp-route-bookId="@Model.Id" class="btn btn-success">Borrow This Book</a>
                }
                <a asp-controller="Feedback" asp-action="Create" asp-route-bookId="@Model.Id" class="btn btn-info">Leave Feedback</a>
            </div>
        </div>
    </div>

    @if (Model.Feedbacks != null && Model.Feedbacks.Any())
    {
        <h3 class="mt-4">Feedback</h3>
        <div class="row">
            @foreach (var feedback in Model.Feedbacks)
            {
                <div class="col-md-6 mb-3">
                    <div class="card">
                        <div class="card-body">
                            <p class="card-text">@feedback.Comment</p>
                            <p class="text-muted mb-0">
                                Rating: @feedback.Rating/5 | By: @feedback.UserEmail
                            </p>
                            <small class="text-muted">@feedback.CreatedAt.ToShortDateString()</small>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
