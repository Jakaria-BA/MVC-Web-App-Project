@model LibraryMVC.Models.Library

@{
    ViewData["Title"] = "Delete Library";
}

<div class="container mt-4">
    <h1>Delete Library</h1>
    <h3 class="text-danger">Are you sure you want to delete this library?</h3>
    <p class="text-muted">Books in this library will not be deleted, but will be unlinked.</p>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Name)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Name)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Address)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Address)</dd>
            </dl>

            <form asp-action="Delete">
                <input type="hidden" asp-for="Id" />
                <input type="submit" value="Delete" class="btn btn-danger" />
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </form>
        </div>
    </div>
</div>
