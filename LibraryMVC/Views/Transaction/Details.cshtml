@model LibraryMVC.Models.Transaction

@{
    ViewData["Title"] = "Transaction Details";
}

<div class="container mt-4">
    <h1>Transaction Details</h1>

    <div class="card">
        <div class="card-body">
            <dl class="row">
                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Book)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.Book.Title)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.MemberEmail)</dt>
                <dd class="col-sm-9">@Html.DisplayFor(model => model.MemberEmail)</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.BorrowDate)</dt>
                <dd class="col-sm-9">@Model.BorrowDate.ToString("MMMM dd, yyyy hh:mm tt")</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.DueDate)</dt>
                <dd class="col-sm-9">@Model.DueDate.ToString("MMMM dd, yyyy")</dd>

                <dt class="col-sm-3">@Html.DisplayNameFor(model => model.ReturnDate)</dt>
                <dd class="col-sm-9">
                    @(Model.ReturnDate.HasValue ? Model.ReturnDate.Value.ToString("MMMM dd, yyyy hh:mm tt") : "Not returned")
                </dd>

                <dt class="col-sm-3">Fine Amount</dt>
                <dd class="col-sm-9">
                    @if (Model.FineAmount > 0)
                    {
                        <span class="text-danger">$@Model.FineAmount.ToString("F2")</span>
                    }
                    else
                    {
                        @:None
                    }
                </dd>

                <dt class="col-sm-3">Status</dt>
                <dd class="col-sm-9">
                    @if (Model.ReturnDate.HasValue)
                    {
                        <span class="badge bg-secondary">Returned</span>
                    }
                    else if (Model.IsOverdue)
                    {
                        <span class="badge bg-danger">Overdue</span>
                        <p class="text-muted mt-1">
                            Overdue by @((DateTime.Now - Model.DueDate).Days) days
                        </p>
                    }
                    else
                    {
                        <span class="badge bg-success">Active</span>
                    }
                </dd>
            </dl>
            <div class="mt-3">
                @if (!Model.ReturnDate.HasValue)
                {
                    <a asp-action="Return" asp-route-id="@Model.Id" class="btn btn-success">Return Book</a>
                }
                <a asp-action="Index" class="btn btn-secondary">Back to List</a>
            </div>
        </div>
    </div>
</div>
